[Unit]
Description=Remount all filesystems and restart Plex after boot
Wants=network-online.target
After=network-online.target docker.service
Requires=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
TimeoutStartSec=30min
ExecStart=/usr/local/bin/plex-boot-fix.sh

[Install]
WantedBy=multi-user.target
